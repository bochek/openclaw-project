# OpenClaw Docker Configuration

# --- TOGETHER AI LLM ---
TOGETHER_API_KEY=YOUR_TOGETHER_KEY
LLM_MODEL=together_ai/meta-llama/Llama-3-70b-chat-hf
# or: together_ai/qwen/Qwen2-72B-Instruct

# --- TELEGRAM BOT ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# --- WHATSAPP (Mojo/Bridge) ---
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_PATH=./data/whatsapp_session

# --- GOOGLE DRIVE / DOCS ---
GOOGLE_SERVICE_ACCOUNT_PATH=/app/config/google_service_account.json

# --- CLOUDFLARE ACCESS (For MCP Tunnel) ---
CF_ACCESS_CLIENT_ID=YOUR_CF_ACCESS_CLIENT_ID
CF_ACCESS_CLIENT_SECRET=YOUR_CF_ACCESS_CLIENT_SECRET
MCP_REMOTE_URL=https://mcp.mydomain.com

# --- OPENCLAW SETTINGS ---
OPENCLAW_LOG_LEVEL=INFO
DATA_DIR=/app/data
