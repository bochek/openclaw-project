# OpenClaw Docker Configuration

# --- TOGETHER AI LLM ---
TOGETHER_API_KEY=YOUR_TOGETHER_KEY
LLM_MODEL=together_ai/meta-llama/Llama-3-70b-chat-hf
# or: together_ai/qwen/Qwen2-72B-Instruct

# --- TELEGRAM BOT ---
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_CHAT_ID=YOUR_TELEGRAM_CHAT_ID

# --- WHATSAPP (Mojo/Bridge) ---
WHATSAPP_ENABLED=true
WHATSAPP_SESSION_PATH=./data/whatsapp_session

# --- GOOGLE DRIVE / DOCS ---
GOOGLE_SERVICE_ACCOUNT_PATH=/app/config/google_service_account.json

# --- CLOUDFLARE ACCESS (Deprecated for Render/Tailscale) ---
# CF_ACCESS_CLIENT_ID=...

# --- TAILSCALE (For Render <-> Local MCP) ---
TS_AUTHKEY=tskey-auth-YOUR_KEY_HERE
TS_HOSTNAME=openclaw-render

# --- OPENCLAW SETTINGS ---
OPENCLAW_LOG_LEVEL=INFO
DATA_DIR=/app/data

# --- MISSION CONTROL DASHBOARD ---
MISSION_CONTROL_PORT=3001
AUTH_USER=admin
AUTH_PASS=password123
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=YOUR_NEXTAUTH_SECRET
