services:
  postgres:
    image: postgres:16-alpine
    container_name: tasks-postgres
    environment:
      - POSTGRES_USER=postgres
      - POSTGRES_PASSWORD=postgres
      - POSTGRES_DB=goclaw
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: [ "CMD-SHELL", "pg_isready -U postgres" ]
      interval: 5s
      timeout: 5s
      retries: 5

  tasks-api:
    build:
      context: ./tasks-api
      dockerfile: Dockerfile
    container_name: tasks-api
    ports:
      - "8082:8082"
    environment:
      - DATABASE_URL=postgres://postgres:postgres@postgres:5432/goclaw?sslmode=disable
      - PORT=8082
    depends_on:
      postgres:
        condition: service_healthy

  kanban:
    image: nginx:alpine
    container_name: kanban-ui
    ports:
      - "8080:80"
    volumes:
      - ./tasks-api/kanban.html:/usr/share/nginx/html/index.html:ro
    depends_on:
      - tasks-api

  local-mcp:
    build:
      context: ./local_mcp
    container_name: local-mcp
    ports:
      - "8005:8000"
    volumes:
      - ./local_mcp/chroma_db:/app/chroma_db
    environment:
      - OLLAMA_URL=http://host.docker.internal:11434
      - EMBEDDING_MODEL=qwen3-embedding
      - WHISPER_MODEL_SIZE=base
    extra_hosts:
      - "host.docker.internal:host-gateway"

  context7:
    image: node:22-alpine
    container_name: context7
    restart: unless-stopped
    ports:
      - "9001:8000"
    environment:
      - HOST=0.0.0.0
    command: >
      npx -y @upstash/context7-mcp --transport http --port 8000

  mcp-docker:
    build:
      context: .
      dockerfile: Dockerfile.mcp
    container_name: mcp-docker
    restart: unless-stopped
    ports:
      - "8002:8000"
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock
    command: [ "--log-level", "DEBUG", "--port", "8000", "--host", "0.0.0.0", "--", "npx", "-y", "@docker/mcp-server" ]

  mcp-github:
    build:
      context: .
      dockerfile: Dockerfile.mcp
    container_name: mcp-github
    restart: unless-stopped
    ports:
      - "8003:8000"
    environment:
      - GITHUB_PERSONAL_ACCESS_TOKEN=${GITHUB_TOKEN}
    command: [ "--port", "8000", "--host", "0.0.0.0", "--", "npx", "-y", "@modelcontextprotocol/server-github" ]

  mcp-maton:
    build:
      context: .
      dockerfile: Dockerfile.mcp
    container_name: mcp-maton
    restart: unless-stopped
    ports:
      - "8004:8000"
    environment:
      - MATON_API_KEY=${MATON_API_KEY}
    command: [ "--log-level", "DEBUG", "--port", "8000", "--host", "0.0.0.0", "--", "npx", "@maton/mcp" ]

volumes:
  postgres_data:
